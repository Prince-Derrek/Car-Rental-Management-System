@model List<CRMS_UI.ViewModels.Cars.CarViewModel>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Our Fleet";
    var userRole = Context.Session.GetString("UserRole");
    var isOwner = userRole == "Owner";
}

<div class="py-8">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900">@ViewData["Title"]</h1>
            <p class="text-gray-500 mt-1">Browse and filter our premium vehicle selection.</p>
        </div>

        @if (isOwner)
        {
            <a asp-controller="Cars" asp-action="Create" class="flex items-center px-5 py-2.5 border border-transparent text-sm font-bold rounded-lg text-white bg-green-600 hover:bg-green-700 shadow-lg transition duration-150 transform hover:-translate-y-0.5">
                <i class="fa-solid fa-plus mr-2"></i> Add New Vehicle
            </a>
        }
    </div>

    <div class="bg-white p-6 rounded-xl shadow-md border border-gray-100 mb-8">
        <form method="get" asp-action="Index" class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-6 gap-4 items-end">
            <div>
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-1">Make</label>
                <input type="text" name="make" value="@ViewBag.Make" placeholder="e.g. Toyota"
                       class="w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
            </div>

            <div>
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-1">Model</label>
                <input type="text" name="model" value="@ViewBag.Model" placeholder="e.g. Camry"
                       class="w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
            </div>

            <div>
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-1">Min Price</label>
                <input type="number" name="minPrice" value="@ViewBag.MinPrice" placeholder="Ksh"
                       class="w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
            </div>

            <div>
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-1">Max Price</label>
                <input type="number" name="maxPrice" value="@ViewBag.MaxPrice" placeholder="Ksh"
                       class="w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
            </div>

            <div class="lg:col-span-2 flex gap-2">
                <button type="submit" class="flex-1 bg-indigo-600 text-white px-4 py-2 rounded-md font-bold hover:bg-indigo-700 transition shadow-sm">
                    <i class="fa-solid fa-magnifying-glass mr-2"></i> Search
                </button>
                <a asp-action="Index" class="flex-1 bg-gray-100 text-gray-700 px-4 py-2 rounded-md font-bold hover:bg-gray-200 text-center transition">
                    Clear
                </a>
            </div>
        </form>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-green-100 border-l-4 border-green-500 text-green-700 px-4 py-3 rounded shadow-sm mb-6" role="alert">
            <p class="font-bold">Success</p>
            <p class="text-sm">@TempData["SuccessMessage"]</p>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-red-100 border-l-4 border-red-500 text-red-700 px-4 py-3 rounded shadow-sm mb-6" role="alert">
            <p class="font-bold">Error</p>
            <p class="text-sm">@TempData["ErrorMessage"]</p>
        </div>
    }

    <div class="bg-white overflow-hidden shadow-xl sm:rounded-xl border border-gray-200">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-widest">Vehicle Details</th>
                    <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-widest">Year</th>
                    <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-widest">Daily Rate</th>
                    <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-widest">Status</th>
                    <th class="relative px-6 py-4"><span class="sr-only">Actions</span></th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="px-6 py-10 text-center text-gray-500 italic">
                            No vehicles found matching your criteria. Try adjusting your filters.
                        </td>
                    </tr>
                }
                @foreach (var car in Model)
                {
                    <tr class="hover:bg-gray-50 transition duration-100">
                        <td class="px-6 py-4">
                            <div class="flex items-center">
                                <div class="bg-indigo-100 p-2 rounded-lg mr-4">
                                    <i class="fa-solid fa-car text-indigo-600"></i>
                                </div>
                                <div>
                                    <div class="text-sm font-bold text-gray-900">@car.Make @car.Model</div>
                                    <div class="text-xs text-gray-500">Plate: @car.Plate</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 font-medium">@car.Year</td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <span class="text-sm font-extrabold text-gray-900">Ksh @car.PricePerDay.ToString("N0")</span>
                            <span class="text-xs text-gray-500">/ day</span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            @{
                                var badgeStyle = car.IsAvailable ? "bg-green-100 text-green-800 border-green-200" : "bg-red-100 text-red-800 border-red-200";
                            }
                            <span class="px-3 py-1 inline-flex text-xs leading-5 font-bold rounded-full border @badgeStyle">
                                @car.CurrentStatus
                            </span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-bold">
                            @if (isOwner)
                            {
                                <a asp-controller="Cars" asp-action="Edit" asp-route-id="@car.Id" class="text-indigo-600 hover:text-indigo-900 mr-4">Edit</a>
                                <form asp-controller="Cars" asp-action="Delete" asp-route-id="@car.Id" method="post" class="inline" onsubmit="return confirm('Delete this vehicle?');">
                                    <button type="submit" class="text-red-600 hover:text-red-900">Delete</button>
                                    @Html.AntiForgeryToken()
                                </form>
                            }
                            else
                            {
                                <a asp-controller="Rentals" asp-action="Rent" asp-route-id="@car.Id"
                                   class="inline-flex items-center px-4 py-2 bg-indigo-600 text-white rounded-md text-xs hover:bg-indigo-700 transition">
                                    Book Now
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>