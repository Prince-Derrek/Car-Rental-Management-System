@model CRMS_UI.ViewModels.Dashboard.SuperAdminDashboardViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Super Admin Dashboard";
}

<div class="py-8">
    <h1 class="text-3xl font-extrabold text-gray-900">Welcome, @Model.UserName (Super Admin)</h1>
    <p class="mt-2 text-lg text-gray-600">System-Wide Analytics Overview.</p>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative my-4" role="alert">
            <span class="block sm:inline">@TempData["SuccessMessage"]</span>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative my-4" role="alert">
            <span class="block sm:inline">@TempData["ErrorMessage"]</span>
        </div>
    }

    <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
    </div>

    <div class="mt-10 grid grid-cols-1 gap-8 lg:grid-cols-2">
        <div class="bg-white p-6 shadow-lg rounded-xl border border-gray-200">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-xl font-bold text-gray-800">Revenue Performance</h2>
                <span class="text-sm font-semibold text-green-600 bg-green-50 px-2 py-1 rounded">System-Wide</span>
            </div>
            <div class="relative" style="height: 300px;">
                <canvas id="revenueChart"></canvas>
            </div>
        </div>

        <div class="bg-white p-6 shadow-lg rounded-xl border border-gray-200">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-xl font-bold text-gray-800">Booking Status Breakdown</h2>
                <i class="fa-solid fa-chart-pie text-gray-400"></i>
            </div>
            <div class="relative flex justify-center" style="height: 300px;">
                <canvas id="statusChart"></canvas>
            </div>
        </div>
    </div>

    <div class="mt-10 bg-white shadow-lg rounded-xl p-6">
        <h2 class="text-xl font-bold text-gray-900 border-b pb-3 mb-4">Management Actions</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
            <a asp-action="UserList" asp-controller="SuperAdmin" class="flex items-center justify-center p-4 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-100 transition duration-150 shadow-sm">
                <i class="fa-solid fa-users-gear mr-2 text-lg text-blue-500"></i>
                <span class="font-medium">Manage Users</span>
            </a>
            <span class="flex items-center justify-center p-4 border border-gray-200 rounded-lg text-gray-400 bg-gray-50">
                (Future Actions Placeholder)
            </span>
            <span class="flex items-center justify-center p-4 border border-gray-200 rounded-lg text-gray-400 bg-gray-50">
                (Future Actions Placeholder)
            </span>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // 1. Revenue Line Chart
        const revCtx = document.getElementById('revenueChart').getContext('2d');
        new Chart(revCtx, {
            type: 'line',
            data: {
                labels: ['Week 1', 'Week 2', 'Week 3', 'Week 4'], // Will be dynamic in next phase
                datasets: [{
                    label: 'Revenue (Ksh)',
                    data: [(@Model.TotalRevenue * 0.2), (@Model.TotalRevenue * 0.5), (@Model.TotalRevenue * 0.8), @Model.TotalRevenue],
                    borderColor: '#10B981',
                    backgroundColor: 'rgba(16, 185, 129, 0.1)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 5
                }]
            },
            options: { responsive: true, maintainAspectRatio: false }
        });

        // 2. Status Doughnut Chart
        const statusCtx = document.getElementById('statusChart').getContext('2d');
        new Chart(statusCtx, {
            type: 'doughnut',
            data: {
                labels: ['Active', 'Pending', 'Completed'],
                datasets: [{
                    data: [@Model.ActiveBookings, @Model.PendingBookings, @Model.CompletedBookings],
                    backgroundColor: ['#4F46E5', '#F59E0B', '#10B981'],
                    hoverOffset: 10
                }]
            },
            options: { responsive: true, maintainAspectRatio: false }
        });
    </script>
}