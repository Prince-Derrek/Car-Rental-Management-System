@model CRMS_UI.ViewModels.Dashboard.AdminDashboardViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Admin Dashboard";
    var userName = Context.Session.GetString("UserName") ?? "Admin";
}

<div class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
        <h1 class="text-3xl font-extrabold text-gray-900">Welcome back, @Model.UserName (Owner)</h1>
        <p class="mt-2 text-lg text-gray-600">Overview of the rental system and fleet management controls.</p>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <div class="bg-white overflow-hidden shadow-lg rounded-xl border border-indigo-200">
            <div class="p-5">
                <div class="flex items-center">
                    <div class="flex-shrink-0 bg-indigo-500 rounded-full p-3 text-white">
                        <i class="fa-solid fa-key text-xl"></i>
                    </div>
                    <div class="ml-5 w-0 flex-1">
                        <dl>
                            <dt class="text-sm font-medium text-gray-500 truncate">Active Rentals</dt>
                            <dd class="text-3xl font-extrabold text-gray-900">@Model.ActiveRentals</dd>
                        </dl>
                    </div>
                </div>
            </div>
            <div class="bg-gray-50 px-5 py-3 text-sm">
                <a asp-controller="Rentals" asp-action="Index" class="font-medium text-indigo-600 hover:text-indigo-500">View All Bookings <i class="fa-solid fa-arrow-right-long ml-1"></i></a>
            </div>
        </div>

        <div class="bg-white overflow-hidden shadow-lg rounded-xl border border-green-200">
            <div class="p-5">
                <div class="flex items-center">
                    <div class="flex-shrink-0 bg-green-500 rounded-full p-3 text-white">
                        <i class="fa-solid fa-car text-xl"></i>
                    </div>
                    <div class="ml-5 w-0 flex-1">
                        <dl>
                            <dt class="text-sm font-medium text-gray-500 truncate">Total Vehicles</dt>
                            <dd class="text-3xl font-extrabold text-gray-900">@Model.TotalVehicles</dd>
                        </dl>
                    </div>
                </div>
            </div>
            <div class="bg-gray-50 px-5 py-3 text-sm">
                <a asp-controller="Cars" asp-action="Index" class="font-medium text-green-600 hover:text-green-500">Manage Fleet <i class="fa-solid fa-arrow-right-long ml-1"></i></a>
            </div>
        </div>

        <div class="bg-white overflow-hidden shadow-lg rounded-xl border border-yellow-200">
            <div class="p-5">
                <div class="flex items-center">
                    <div class="flex-shrink-0 bg-yellow-500 rounded-full p-3 text-white">
                        <i class="fa-solid fa-clock-rotate-left text-xl"></i>
                    </div>
                    <div class="ml-5 w-0 flex-1">
                        <dl>
                            <dt class="text-sm font-medium text-gray-500 truncate">Pending Approvals</dt>
                            <dd class="text-3xl font-extrabold text-gray-900">@Model.PendingApprovals</dd>
                        </dl>
                    </div>
                </div>
            </div>
            <div class="bg-gray-50 px-5 py-3 text-sm">
                <a asp-controller="Rentals" asp-action="Index" class="font-medium text-yellow-600 hover:text-yellow-500">Review Requests <i class="fa-solid fa-arrow-right-long ml-1"></i></a>
            </div>
        </div>

        <div class="bg-white overflow-hidden shadow-lg rounded-xl border border-blue-200">
            <div class="p-5">
                <div class="flex items-center">
                    <div class="flex-shrink-0 bg-blue-500 rounded-full p-3 text-white">
                        <i class="fa-solid fa-location-dot text-xl"></i>
                    </div>
                    <div class="ml-5 w-0 flex-1">
                        <dl>
                            <dt class="text-sm font-medium text-gray-500 truncate">Tracking Enabled</dt>
                            <dd class="text-3xl font-extrabold text-gray-900">@Model.TrackingEnabledPercent %</dd>
                        </dl>
                    </div>
                </div>
            </div>
            <div class="bg-gray-50 px-5 py-3 text-sm">
                <a asp-controller="Tracking" asp-action="Index" class="font-medium text-blue-600 hover:text-blue-500">View Live Map <i class="fa-solid fa-arrow-right-long ml-1"></i></a>
            </div>
        </div>
    </div>

    <div class="mt-10 grid grid-cols-1 gap-8 lg:grid-cols-2">
        <div class="bg-white p-6 shadow-lg rounded-xl border border-gray-200">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-bold text-gray-800">Fleet Utilization</h3>
                <span class="text-xs font-semibold px-2 py-1 bg-indigo-50 text-indigo-600 rounded">Live Status</span>
            </div>
            <div class="relative" style="height: 300px;">
                <canvas id="utilizationChart"></canvas>
            </div>
        </div>

        <div class="bg-white p-6 shadow-lg rounded-xl border border-gray-200 flex flex-col items-center">
            <h3 class="text-lg font-bold text-gray-800 self-start mb-4">Tracking Coverage</h3>
            <div class="relative flex-1 w-full flex justify-center items-center" style="max-height: 250px;">
                <canvas id="trackingGauge"></canvas>
                <div class="absolute mt-8 text-center">
                    <span class="text-2xl font-bold text-gray-800">@Model.TrackingEnabledPercent%</span>
                    <p class="text-xs text-gray-500">GPS Active</p>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-10 bg-white shadow-lg rounded-xl p-6">
        <h2 class="text-xl font-bold text-gray-900 border-b pb-3 mb-4">Quick Actions</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
            <a asp-controller="Cars" asp-action="Create" class="flex items-center justify-center p-4 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-100 transition duration-150 shadow-sm">
                <i class="fa-solid fa-plus-circle mr-2 text-lg text-green-500"></i>
                <span class="font-medium">Add New Vehicle</span>
            </a>
            <a asp-controller="Rentals" asp-action="Index" class="flex items-center justify-center p-4 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-100 transition duration-150 shadow-sm">
                <i class="fa-solid fa-list-check mr-2 text-lg text-indigo-500"></i>
                <span class="font-medium">Manage All Rentals</span>
            </a>
            <a asp-controller="Tracking" asp-action="Index" class="flex items-center justify-center p-4 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-100 transition duration-150 shadow-sm">
                <i class="fa-solid fa-gauge-high mr-2 text-lg text-blue-500"></i>
                <span class="font-medium">Monitor Telemetry Feed</span>
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        // Utilization Bar Chart
        const utilCtx = document.getElementById('utilizationChart').getContext('2d');
        new Chart(utilCtx, {
            type: 'bar',
            data: {
                labels: ['Total Fleet', 'Active Rentals', 'Pending Approvals'],
                datasets: [{
                    label: 'Count',
                    data: @Html.Raw(Json.Serialize(Model.UtilizationValues)),
                    backgroundColor: ['#94a3b8', '#6366f1', '#f59e0b'],
                    borderRadius: 6,
                    barThickness: 40
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, ticks: { stepSize: 1 } },
                    x: { grid: { display: false } }
                }
            }
        });

        // Tracking Health Gauge (Semi-Doughnut)
        const trackCtx = document.getElementById('trackingGauge').getContext('2d');
        new Chart(trackCtx, {
            type: 'doughnut',
            data: {
                labels: ['Enabled', 'Disabled'],
                datasets: [{
                    data: @Html.Raw(Json.Serialize(Model.TrackingGaugeData)),
                    backgroundColor: ['#3b82f6', '#f1f5f9'],
                    borderWidth: 0,
                    weight: 0.5
                }]
            },
            options: {
                rotation: -90,
                circumference: 180,
                cutout: '85%',
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } }
            }
        });
    </script>
}